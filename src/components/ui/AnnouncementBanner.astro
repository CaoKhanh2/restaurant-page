<div class="announcement-banner" data-announcement-banner hidden>
  <div class="announcement-banner__inner" data-announcement-list></div>
</div>

<script>
  const bannerRoot = document.querySelector('[data-announcement-banner]');
  const bannerList = bannerRoot?.querySelector('[data-announcement-list]');

  const appendText = (parent, tagName, className, text) => {
    if (!text) return;
    const element = document.createElement(tagName);
    element.className = className;
    element.textContent = text;
    parent.append(element);
  };

  const renderAnnouncements = (banners) => {
    if (!bannerRoot || !bannerList || !Array.isArray(banners) || banners.length === 0) return;

    const fragment = document.createDocumentFragment();
    banners.forEach((banner) => {
      const item = document.createElement('article');
      item.className = 'announcement-banner__item';

      const icon = document.createElement('span');
      icon.className = 'announcement-banner__icon';
      icon.setAttribute('aria-hidden', 'true');
      icon.innerHTML = '<i class="fa-solid fa-bullhorn"></i>';
      item.append(icon);

      const content = document.createElement('div');
      content.className = 'announcement-banner__content';
      appendText(content, 'strong', 'announcement-banner__title', banner.title || 'Annonce');
      appendText(content, 'p', 'announcement-banner__message', banner.message);
      item.append(content);

      fragment.append(item);
    });

    bannerList.replaceChildren(fragment);
    bannerRoot.hidden = false;
  };

  const loadAnnouncements = async () => {
    try {
      const response = await fetch('/api/banners.php', { headers: { Accept: 'application/json' } });
      if (!response.ok) return;

      const data = await response.json();
      renderAnnouncements(data.banners);
    } catch (error) {
      // Public page should stay silent if the PHP API is unavailable in local dev.
    }
  };

  loadAnnouncements();
</script>

<style>
  .announcement-banner[hidden] {
    display: none;
  }

  .announcement-banner {
    margin-top: 105px;
    padding: 0.75rem 5%;
    background:
      linear-gradient(90deg, rgba(106, 15, 18, 0.92), rgba(156, 27, 27, 0.86)),
      var(--wine-1);
    border-bottom: 1px solid rgba(201, 162, 75, 0.34);
    box-shadow: 0 12px 34px rgba(12, 8, 5, 0.28);
  }

  .announcement-banner__inner {
    max-width: 1180px;
    margin: 0 auto;
    display: grid;
    gap: 0.65rem;
  }

  :global(.announcement-banner__item) {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    color: #fff8eb;
  }

  :global(.announcement-banner__icon) {
    width: 34px;
    height: 34px;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    color: #2a1c08;
    background: linear-gradient(135deg, var(--gold), var(--gold-bright));
    box-shadow: 0 6px 18px rgba(201, 162, 75, 0.24);
  }

  :global(.announcement-banner__content) {
    min-width: 0;
  }

  :global(.announcement-banner__title) {
    display: block;
    font-family: var(--font-heading);
    font-size: 1.02rem;
    line-height: 1.2;
    color: #fff;
  }

  :global(.announcement-banner__message) {
    margin: 0.15rem 0 0;
    color: rgba(255, 248, 235, 0.88);
    line-height: 1.45;
  }

  @media (max-width: 768px) {
    .announcement-banner {
      margin-top: 91px;
      padding: 0.8rem 5%;
    }

    :global(.announcement-banner__item) {
      align-items: flex-start;
    }
  }
</style>
