---
import { phone, phoneHref } from '../../data/site.js';
---
<section id="takeaway">
  <span class="eyebrow" data-reveal data-i18n="takeaway.eyebrow">À emporter</span>
  <h2 data-reveal data-i18n="takeaway.title">Restaurant Les 4 Saisons, chez vous</h2>
  <p data-reveal data-i18n="takeaway.desc">Commandez à emporter et savourez nos plats à la maison.</p>
  <a href={phoneHref} class="btn btn-gold" data-reveal>{phone}</a>
</section>
