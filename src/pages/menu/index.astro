---
import Layout from '../../layouts/Layout.astro';
import { menuData, menuOrder } from '../../data/menu.js';
import { url } from '../../scripts/utils/url.js';
import '../../styles/pages/menu.css';

// Link chi tiết món — build sẵn query-param (giữ URL/cơ chế cũ qua url()).
const dishHref = (d) =>
  url('/menu/dish-detail', '?' +
  new URLSearchParams({ name: d.name, image: d.image, description: d.description, price: d.price }).toString());

const keys = menuOrder.filter((k) => menuData[k]);
const catIcons = { potages: 'potages', entrees: 'entrees', dimsum: 'dimsum', poulet: 'poulet', boeuf: 'boeuf' };
const splitTitle = (t) => { const i = t.indexOf('/'); return i === -1 ? { fr: t.trim(), en: '' } : { fr: t.slice(0, i).trim(), en: t.slice(i + 1).trim() }; };
const isPlaceholder = (img) => !img || img.includes('placeholder');
const isSpicy = (name) => name.includes('🌶');
const cleanName = (name) => name.replace(/🌶️/g, '').replace(/🌶/g, '').trim();

const setMenus = [
  { title: 'Menu végétarien', condition: 'Au minimum pour 2 personnes', price: '41.- / pers.', items: ['Potage pékinois piquant 🌶️','Rouleaux de printemps aux légumes','Légumes sautés aux champignons chinois','Tofu au curry rouge','Riz ou nouilles sautées au choix','Dessert au choix'] },
  { title: 'Menu 1', condition: 'Au minimum pour 2 personnes', price: '41.- / pers.', items: ['Potage pékinois piquant 🌶️','Rouleaux de printemps aux légumes','Poulet sauté Sichuan piquant 🌶️','Crevettes sur ardoise','Riz ou nouilles sautées au choix','Dessert au choix'] },
  { title: 'Menu 3', condition: 'Au minimum pour 2 personnes', price: '60.- / pers.', items: ['Potage pékinois piquant 🌶️','Rouleaux de printemps vietnamiens «Nems»','Crevettes à la sauce aigre-douce','Magret de canard sur ardoise','Poulet sauté aux légumes','Riz ou nouilles sautées au choix','Dessert au choix'] },
  { title: 'Menu spécial «Canard Laqué»', condition: 'Au minimum pour 2 personnes', price: '60.- / pers.', items: ['Potage aux fruits de mer','Peau de canard croustillante avec crêpes','Canard sauté aux pousses de soja','Riz ou nouilles sautées au choix','Dessert au choix'] },
];
---
<Layout
  title="La Carte Des Mets - Restaurant Les 4 Saisons"
  description="Découvrez notre carte et nos menus spéciaux au restaurant Les 4 Saisons, des célèbres Dim Sum au Canard laqué de Pékin et aux spécialités sichuanaises."
>
  <section id="full-menu-page">
    <div class="menu-header" data-reveal>
      <span class="subtitle" data-i18n="menu.subtitle">Menu</span>
      <h1 data-i18n="menu.title">Découvrez nos plats</h1>
      <div class="decorator">◆</div>
      <div class="menu-legend">
        <span class="leg"><span class="ico">🌶️</span><span data-i18n="menu.legend.spicy">Épicé</span></span>
        <span class="leg"><span class="ico">🌱</span><span data-i18n="menu.legend.veg">Végétarien</span></span>
      </div>
    </div>

    <!-- Thanh tab danh mục (sticky) -->
    <nav class="menu-tabs" aria-label="Catégories du menu">
      <div class="menu-tabs-inner" id="menu-tabs-inner">
        <button class="menu-tab active" type="button" data-target="cat-menus" data-i18n="menu.tab.formules">Formules</button>
        {keys.map((k) => (
          <button class="menu-tab" type="button" data-target={`cat-${k}`}>{splitTitle(menuData[k].title).fr}</button>
        ))}
      </div>
    </nav>

    <!-- Formules (set menus) -->
    <section id="cat-menus" class="carte-section" data-reveal>
      <div class="carte-section-head">
        <div class="carte-section-titles">
          <h2 data-i18n="menu.formules.title">Nos Formules</h2>
          <p class="carte-section-sub" data-i18n="menu.formules.sub">Choisissez une formule, ou composez à la carte.</p>
        </div>
      </div>
      <div class="set-menus-container">
        {setMenus.map((m) => (
          <div class="set-menu-card">
            <h3>{m.title}</h3>
            <p class="condition">{m.condition}</p>
            <ul>{m.items.map((it) => <li>{it}</li>)}</ul>
            <div class="price">{m.price}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- À la carte — render tĩnh từ menu.js (mỗi danh mục 1 section) -->
    {keys.map((k) => {
      const cat = menuData[k];
      const { fr, en } = splitTitle(cat.title);
      const icon = catIcons[k];
      const veg = k === 'vegetariens';
      return (
        <section id={`cat-${k}`} class="carte-section" data-reveal>
          <div class="carte-section-head">
            {icon && (
              <picture class="carte-cat-icon">
                <source srcset={`/icon/icon-${icon}-new.webp`} type="image/webp" />
                <img src={`/icon/icon-${icon}-new.jpg`} alt="" width="56" height="56" loading="lazy" />
              </picture>
            )}
            <div class="carte-section-titles">
              <h2>{fr}</h2>
              {en && <span class="carte-section-sub">{en}</span>}
            </div>
          </div>

          <div class="carte-grid">
            {cat.items.map((d) => (
              <a class={`carte-card${d.featured ? ' is-featured' : ''}`} href={dishHref(d)}>
                <div class="carte-card-media">
                  {isPlaceholder(d.image) ? (
                    <div class="carte-card-fallback">
                      <i class="fa-solid fa-bowl-food"></i>
                      <span>Les 4 Saisons</span>
                    </div>
                  ) : (
                    <img src={d.image} alt={cleanName(d.name)} loading="lazy" />
                  )}
                  {d.featured && <span class="carte-badge" data-i18n="menu.signature">Signature</span>}
                </div>
                <div class="carte-card-body">
                  {(isSpicy(d.name) || veg) && (
                    <div class="carte-card-tags">
                      {isSpicy(d.name) && <span class="carte-tag spicy"><span class="ico">🌶️</span><span data-i18n="menu.tag.spicy">Épicé</span></span>}
                      {veg && <span class="carte-tag veg"><span class="ico">🌱</span><span data-i18n="menu.tag.veg">Végé</span></span>}
                    </div>
                  )}
                  <h3 class="carte-card-name">{cleanName(d.name)}</h3>
                  {d.translation && <span class="carte-card-tr">{d.translation}</span>}
                  <span class="carte-card-price">{d.price}.-</span>
                </div>
              </a>
            ))}
          </div>
        </section>
      );
    })}
  </section>
</Layout>

<script>
  // Tab danh mục: click cuộn mượt (Lenis) + active theo scroll (IntersectionObserver). Tĩnh, không fetch.
  const tabs = Array.from(document.querySelectorAll('.menu-tab'));
  const tabsInner = document.querySelector('.menu-tabs-inner');
  const sections = tabs.map((t) => document.getElementById(t.dataset.target)).filter(Boolean);

  const centerTab = (t) => {
    if (!tabsInner) return;
    tabsInner.scrollTo({ left: Math.max(0, t.offsetLeft - (tabsInner.clientWidth - t.clientWidth) / 2), behavior: 'smooth' });
  };
  const setActive = (id) => {
    tabs.forEach((t) => { const on = t.dataset.target === id; t.classList.toggle('active', on); if (on) centerTab(t); });
  };
  tabs.forEach((t) => t.addEventListener('click', () => {
    const el = document.getElementById(t.dataset.target);
    if (!el) return;
    if (window.__lenis) window.__lenis.scrollTo(el, { offset: -118, duration: 1.1 });
    else { const y = el.getBoundingClientRect().top + window.pageYOffset - 118; window.scrollTo({ top: y, behavior: 'smooth' }); }
  }));
  if ('IntersectionObserver' in window && sections.length) {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => { if (e.isIntersecting) setActive(e.target.id); });
    }, { rootMargin: '-130px 0px -65% 0px', threshold: 0 });
    sections.forEach((s) => obs.observe(s));
  }
</script>
