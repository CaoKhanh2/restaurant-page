---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page introuvable - Restaurant Les 4 Saisons" description="Page introuvable.">
  <section style="min-height:70vh;display:flex;align-items:center;justify-content:center;text-align:center;padding-top:120px;">
    <div data-reveal>
      <span class="eyebrow">Erreur 404</span>
      <h1 style="font-size:clamp(2.5rem,6vw,4rem);margin-bottom:1rem;">Page introuvable</h1>
      <p style="color:var(--text-sub);margin-bottom:2rem;">La page que vous cherchez n'existe pas ou a été déplacée.</p>
      <a href="/" class="btn btn-gold">Retour à l'accueil</a>
    </div>
  </section>
</Layout>
