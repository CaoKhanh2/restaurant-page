---
import Layout from '../layouts/Layout.astro';
import '../styles/pages/gallery.css';
---
<Layout
  title="Galerie - Restaurant Les 4 Saisons"
  description="Parcourez notre galerie de photos pour un aperçu de nos plats savoureux et de l'ambiance élégante et accueillante du restaurant Les 4 Saisons."
>
  <section id="gallery-page">
    <h1 class="gallery-page-title" data-reveal data-i18n="gallery.title">Galerie</h1>
    <p class="gallery-page-sub" data-reveal data-i18n="gallery.sub">Un aperçu de nos plats et de notre ambiance</p>
    <div class="gallery-grid-container" id="gallery-grid" data-reveal-stagger>
      <!-- Populated dynamically from /api/gallery.php -->
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Galerie" aria-hidden="true">
    <button class="lb-btn lb-close" type="button" aria-label="Fermer">&times;</button>
    <button class="lb-btn lb-prev" type="button" aria-label="Image précédente">&#8249;</button>
    <figure class="lb-figure">
      <img class="lb-img" src="" alt="" />
    </figure>
    <button class="lb-btn lb-next" type="button" aria-label="Image suivante">&#8250;</button>
    <div class="lb-counter"></div>
  </div>
</Layout>

<script>
  // Fetch gallery images from PHP API, then init lightbox.
  const grid = document.getElementById('gallery-grid');
  const lb   = document.getElementById('lightbox');

  async function loadGallery() {
    try {
      const res  = await fetch('/api/gallery.php');
      const data = await res.json();
      const imgs = data.images ?? [];

      if (!imgs.length) { grid.innerHTML = '<p style="text-align:center;padding:40px">Galerie en cours de mise à jour.</p>'; return; }

      grid.innerHTML = imgs.map((img, i) => `
        <div class="grid-item" role="button" tabindex="0" aria-label="Agrandir" data-index="${i}">
          <picture>
            <img src="${img.image_path}" alt="${img.alt_text || 'Galerie'}" width="400" height="400" loading="lazy" />
          </picture>
          <span class="grid-zoom" aria-hidden="true"><i class="fa-solid fa-up-right-and-down-left-from-center"></i></span>
        </div>
      `).join('');

      initLightbox(imgs.map(img => ({ src: img.image_path, alt: img.alt_text || '' })));
    } catch (e) {
      grid.innerHTML = '<p style="text-align:center;padding:40px">Impossible de charger la galerie.</p>';
    }
  }

  function initLightbox(photoData) {
    const items = Array.from(grid.querySelectorAll('.grid-item'));
    if (!lb || !items.length) return;
    const lbImg   = lb.querySelector('.lb-img');
    const counter = lb.querySelector('.lb-counter');
    let idx = 0;

    const preload = (i) => { const im = new Image(); im.src = photoData[(i + photoData.length) % photoData.length].src; };
    const show = (i) => {
      idx = (i + photoData.length) % photoData.length;
      const d = photoData[idx];
      lbImg.classList.add('loading');
      const tmp = new Image();
      tmp.onload = () => { lbImg.src = d.src; lbImg.alt = d.alt; lbImg.classList.remove('loading'); };
      tmp.src = d.src;
      counter.textContent = `${idx + 1} / ${photoData.length}`;
      preload(idx + 1); preload(idx - 1);
    };
    const open = (i) => {
      show(i);
      lb.classList.add('open');
      lb.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('lb-open');
      if (window.__lenis) window.__lenis.stop();
    };
    const close = () => {
      lb.classList.remove('open');
      lb.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('lb-open');
      if (window.__lenis) window.__lenis.start();
    };

    items.forEach((it, i) => {
      it.addEventListener('click', () => open(i));
      it.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(i); } });
    });
    lb.querySelector('.lb-close').addEventListener('click', close);
    lb.querySelector('.lb-next').addEventListener('click', (e) => { e.stopPropagation(); show(idx + 1); });
    lb.querySelector('.lb-prev').addEventListener('click', (e) => { e.stopPropagation(); show(idx - 1); });
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowRight') show(idx + 1);
      else if (e.key === 'ArrowLeft') show(idx - 1);
    });
    let sx = 0;
    lb.addEventListener('touchstart', (e) => { sx = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - sx;
      if (Math.abs(dx) > 50) { dx < 0 ? show(idx + 1) : show(idx - 1); }
    }, { passive: true });
  }

  loadGallery();
</script>
