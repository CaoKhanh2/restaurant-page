---
import Layout from '../layouts/Layout.astro';
import '../styles/pages/gallery.css';

const ids = [1, 2, 3, 4, 10, 22, 12, 13, 14, 15, 16, 18, 20, 21, 11];
const photos = ids.map((n) => ({
  webp: `/images/food/food${n}.webp`,
  jpg: `/images/food/food${n}.jpg`,
  alt: `Galerie Image ${n}`,
}));
---
<Layout
  title="Galerie - Restaurant Les 4 Saisons"
  description="Parcourez notre galerie de photos pour un aperçu de nos plats savoureux et de l'ambiance élégante et accueillante du restaurant Les 4 Saisons."
>
  <section id="gallery-page">
    <h1 class="gallery-page-title" data-reveal data-i18n="gallery.title">Galerie</h1>
    <p class="gallery-page-sub" data-reveal data-i18n="gallery.sub">Un aperçu de nos plats et de notre ambiance</p>
    <div class="gallery-grid-container" data-reveal-stagger>
      {photos.map((p, i) => (
        <div class="grid-item" role="button" tabindex="0" aria-label={`Agrandir : ${p.alt}`} data-index={i}>
          <picture>
            <source srcset={p.webp} type="image/webp" />
            <img src={p.jpg} alt={p.alt} width="400" height="400" loading="lazy" />
          </picture>
          <span class="grid-zoom" aria-hidden="true"><i class="fa-solid fa-up-right-and-down-left-from-center"></i></span>
        </div>
      ))}
    </div>
  </section>

  <!-- Lightbox -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Galerie" aria-hidden="true">
    <button class="lb-btn lb-close" type="button" aria-label="Fermer">&times;</button>
    <button class="lb-btn lb-prev" type="button" aria-label="Image précédente">&#8249;</button>
    <figure class="lb-figure">
      <img class="lb-img" src="" alt="" />
    </figure>
    <button class="lb-btn lb-next" type="button" aria-label="Image suivante">&#8250;</button>
    <div class="lb-counter"></div>
  </div>
</Layout>

<script>
  // Lightbox vanilla + progressive upgrade từ /api/gallery.php (giữ ảnh tĩnh nếu API lỗi).
  const lb = document.getElementById('lightbox');
  const grid = document.querySelector('.gallery-grid-container');
  if (lb && grid) {
    const lbImg = lb.querySelector('.lb-img');
    const counter = lb.querySelector('.lb-counter');
    let data = [];
    let idx = 0;

    const preload = (i) => { if (!data.length) return; const im = new Image(); im.src = data[(i + data.length) % data.length].src; };
    const show = (i) => {
      if (!data.length) return;
      idx = (i + data.length) % data.length;
      const d = data[idx];
      lbImg.classList.add('loading');
      const tmp = new Image();
      tmp.onload = () => { lbImg.src = d.src; lbImg.alt = d.alt; lbImg.classList.remove('loading'); };
      tmp.src = d.src;
      counter.textContent = `${idx + 1} / ${data.length}`;
      preload(idx + 1); preload(idx - 1);
    };
    const open = (i) => {
      show(i);
      lb.classList.add('open'); lb.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('lb-open');
      if (window.__lenis) window.__lenis.stop();
    };
    const close = () => {
      lb.classList.remove('open'); lb.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('lb-open');
      if (window.__lenis) window.__lenis.start();
    };
    const next = () => show(idx + 1);
    const prev = () => show(idx - 1);

    // Controls + keyboard + swipe — gắn 1 LẦN (không phụ thuộc danh sách ảnh)
    lb.querySelector('.lb-close').addEventListener('click', close);
    lb.querySelector('.lb-next').addEventListener('click', (e) => { e.stopPropagation(); next(); });
    lb.querySelector('.lb-prev').addEventListener('click', (e) => { e.stopPropagation(); prev(); });
    lb.addEventListener('click', (e) => { if (e.target === lb) close(); });
    document.addEventListener('keydown', (e) => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') close();
      else if (e.key === 'ArrowRight') next();
      else if (e.key === 'ArrowLeft') prev();
    });
    let sx = 0;
    lb.addEventListener('touchstart', (e) => { sx = e.touches[0].clientX; }, { passive: true });
    lb.addEventListener('touchend', (e) => { const dx = e.changedTouches[0].clientX - sx; if (Math.abs(dx) > 50) { dx < 0 ? next() : prev(); } }, { passive: true });

    // (Re)đọc ảnh + gắn click cho item hiện tại của lưới
    function bindItems() {
      const items = Array.from(grid.querySelectorAll('.grid-item'));
      data = items.map((it) => { const im = it.querySelector('img'); return { src: im && im.getAttribute('src'), alt: (im && im.getAttribute('alt')) || '' }; }).filter((d) => d.src);
      items.forEach((it, i) => {
        it.addEventListener('click', () => open(i));
        it.addEventListener('keydown', (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); open(i); } });
      });
    }
    bindItems(); // bản tĩnh

    // Upgrade từ DB nếu có
    (async () => {
      try {
        const res = await fetch('/api/gallery.php', { headers: { Accept: 'application/json' } });
        if (!res.ok) return;
        const imgs = (await res.json()).images ?? [];
        if (!imgs.length) return;
        const esc = (s) => String(s ?? '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
        grid.innerHTML = imgs.map((g, i) =>
          `<div class="grid-item" role="button" tabindex="0" aria-label="Agrandir" data-index="${i}">`
          + `<picture><img src="${esc(g.image_path)}" alt="${esc(g.alt_text || 'Galerie')}" width="400" height="400" loading="lazy"></picture>`
          + `<span class="grid-zoom" aria-hidden="true"><i class="fa-solid fa-up-right-and-down-left-from-center"></i></span></div>`
        ).join('');
        bindItems(); // gắn lại cho ảnh mới
      } catch (e) { /* giữ tĩnh */ }
    })();
  }
</script>
